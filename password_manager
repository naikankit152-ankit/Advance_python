import hashlib

class PasswordManager:
    def __init__(self):
        self.passwords = {}

    def encrypt(self, password):
        return hashlib.sha256(password.encode()).hexdigest()

    def add_password(self, site, password):
        self.passwords[site] = self.encrypt(password)

    def get_password(self, site):
        return self.passwords.get(site, "Not Found")

# Example
pm = PasswordManager()
pm.add_password("gmail", "mypassword123")
print("Encrypted Gmail Password:", pm.get_password("gmail"))