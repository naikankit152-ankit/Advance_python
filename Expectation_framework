#Custom Exception Framework

class OutOfStockError(Exception):
    pass

class InvalidProductIDError(Exception):
    pass


class InventorySystem:

    def __init__(self):
        self.products = {
            "P101": {"name": "Laptop", "stock": 5},
            "P102": {"name": "Phone", "stock": 10},
            "P103": {"name": "Headphones", "stock": 7}
        }

    def display_products(self):
        print("\nAvailable Products:")
        for pid, details in self.products.items():
            print(pid, "-", details["name"], "- Stock:", details["stock"])

    def sell_product(self):
        try:
            pid = input("Enter Product ID: ")
            qty = int(input("Enter quantity: "))

            if pid not in self.products:
                raise InvalidProductIDError("Invalid Product ID")

            if qty > self.products[pid]["stock"]:
                raise OutOfStockError("Not enough stock available")

            self.products[pid]["stock"] -= qty

            print("Product sold successfully")

        except InvalidProductIDError as e:
            print("Error:", e)

        except OutOfStockError as e:
            print("Error:", e)

        except ValueError:
            print("Quantity must be a number")

    def add_stock(self):
        try:
            pid = input("Enter Product ID: ")
            qty = int(input("Enter quantity to add: "))

            if pid not in self.products:
                raise InvalidProductIDError("Invalid Product ID")

            self.products[pid]["stock"] += qty
            print("Stock updated successfully")

        except InvalidProductIDError as e:
            print("Error:", e)

        except ValueError:
            print("Quantity must be numeric")

inventory = InventorySystem()

while True:

    print("\n----- Inventory Management System -----")
    print("1. Display Products")
    print("2. Sell Product")
    print("3. Add Stock")
    print("4. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        inventory.display_products()

    elif choice == "2":
        inventory.sell_product()

    elif choice == "3":
        inventory.add_stock()

    elif choice == "4":
        print("Program Ended")
        break

    else:
        print("Invalid choice")