class Movie:
    def __init__(self, title, showtime, seats):
        self.title = title
        self.showtime = showtime
        self.seats = seats

    def book_ticket(self, seat_no):
        if seat_no in self.seats:
            self.seats.remove(seat_no)
            print(f"Seat {seat_no} booked for {self.title} at {self.showtime}.")
        else:
            print("Seat not available.")

# Example
m1 = Movie("Inception", "7:00 PM", [1,2,3,4,5])
m1.book_ticket(3)
m1.book_ticket(3)
print("Remaining seats:", m1.seats)